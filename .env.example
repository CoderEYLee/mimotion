# ========== 自动 commit/push 用的 Git 托管 PAT（可选, 按 host 配） ==========
# 用于 mimotion.js 运行结束后,自动把加密后的 token 缓存 (encrypted_tokens.data) 提交并推送到 origin
# 脚本按 origin 的 host 自动选用:
#   github.com → PUSH_TOKEN_GITHUB  (GitHub PAT)
#   gitee.com  → PUSH_TOKEN_GITEE  (Gitee 私人令牌, 但 Gitee Go runner 自身会注入 extraHeader, 一般不用配)
# 留空则只生成本地 commit, 不 push, 交给 git 自身认证 (SSH key / credential helper / runner 注入)
# GitHub 申请: Settings → Developer settings → Personal access tokens → Fine-grained tokens
# 仓库权限: 仅勾选本仓库, 权限: Contents = Read and write
# PUSH_TOKEN_GITHUB=ghp_xxxxxxxxxxxxxxxxxxxx
# PUSH_TOKEN_GITEE=xxxxxxxxxxxxxxxxxxxx

# ========== 必填 ==========
# Zepp Life 账号（邮箱或手机号，手机号需带 +86 前缀）
ZEPP_USER=your_email@example.com
# Zepp Life 密码
ZEPP_PASSWORD=your_password

# ========== 步数范围（可选） ==========
# 根据北京时间线性增长，22点达到最大值
MIN_STEP=20000
MAX_STEP=20100

# ========== 加密缓存（可选，16字节密钥） ==========
# 用于本地缓存 token 的 AES 加密密钥，长度必须为 16 字节
AES_KEY=your_16byte_key!

# ========== 推送渠道（按需填写，不填则跳过） ==========

# PushPlus（推送到微信）https://www.pushplus.plus/
PUSH_PLUS_TOKEN=
PUSH_PLUS_HOUR=
PUSH_PLUS_MAX=30

# 企业微信机器人 Webhook Key
WECHAT_WEBHOOK_KEY=

# 飞书机器人 Webhook Key
FEISHU_WEBHOOK_KEY=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
